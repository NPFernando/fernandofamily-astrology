{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@fernandofamily/feature-registry": [
        "../../packages/feature-registry/index.ts"
      ],
      "@fernandofamily/design-system": [
        "../../packages/design-system/tokens.ts"
      ],
      "@fernandofamily/contracts": [
        "../../packages/contracts/api-types.d.ts"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "../../packages/feature-registry/index.ts",
    "../../packages/design-system/tokens.ts",
    "../../packages/contracts/api-types.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
