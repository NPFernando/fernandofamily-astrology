APP_NAME=Fernando Family Astrology
APP_ENV=production
PUBLIC_BASE_URL=https://astrology.fernandofamily.com
PUBLIC_REPOSITORY_URL=https://github.com/NPFernando/fernandofamily-astrology
DEFAULT_LOCALE=si
SUPPORTED_LOCALES=en,si
DEFAULT_TIMEZONE=Asia/Colombo
DEFAULT_LOCATION_NAME=Colombo, Sri Lanka
DEFAULT_LATITUDE=6.9271
DEFAULT_LONGITUDE=79.8612
DEFAULT_BIRD=peacock
PYJHORA_VERSION=4.8.7
PYJHORA_COMMIT=ca22995709bd60e371e7820a1a5efc80ce4cf821
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=https://astrology.fernandofamily.com

# Container-to-container API proxy target for the web service (see
# docker-compose.yml) — leave as-is unless you rename the api service.
API_PROXY_TARGET=http://api:8000

# Set automatically by CI/deploy to the built image's git commit SHA; do not
# set by hand in production (see docs/licensing.md's AGPL section 13 note).
GIT_SHA=dev
